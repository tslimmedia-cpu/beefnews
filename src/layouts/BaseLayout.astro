---
import "../styles/globals.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  article?: boolean;
  publishedTime?: string;
  author?: string;
  keywords?: string[];
}

const {
  title = "Beef News — The Voice of the Rancher Direct Movement",
  description = "Breaking news, deep-dives, and market intelligence for the Rancher Direct beef industry.",
  image = "/og-default.jpg",
  article = false,
  publishedTime,
  author,
  keywords = [],
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const siteUrl = "https://beefnews.org";
const siteName = "Beef News";

// ── JSON-LD: Organization (emitted on every page) ─────────────────────────────
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "NewsMediaOrganization",
  "@id": `${siteUrl}/#organization`,
  "name": siteName,
  "alternateName": "BeefNews.org",
  "url": siteUrl,
  "logo": {
    "@type": "ImageObject",
    "url": `${siteUrl}/og-default.jpg`,
  },
  "description": "The Voice of the Rancher Direct Movement. Investigative journalism and market intelligence for independent American ranchers.",
  "foundingOrganization": {
    "@type": "Organization",
    "name": "The Beef Initiative",
    "url": "https://beefmaps.com",
  },
  "sameAs": [
    "https://beefmaps.com",
    "https://x.com/BeefInitiative",
  ],
  "knowsAbout": [
    "Beef Industry", "Rancher Direct Markets", "Food Sovereignty",
    "Cattle Markets", "USDA Policy", "Meatpacker Monopoly",
    "Agricultural Policy", "Raw Milk", "Land Rights", "Beef Initiative",
  ],
};

// ── JSON-LD: WebSite with search action ───────────────────────────────────────
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteUrl}/#website`,
  "name": siteName,
  "url": siteUrl,
  "description": description,
  "publisher": { "@id": `${siteUrl}/#organization` },
  "inLanguage": "en-US",
};
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#131313" />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(", ")} />}
    {author && <meta name="author" content={author} />}
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content={article ? "article" : "website"} />
    <meta property="og:site_name" content="Beef News" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="en_US" />
    {article && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {article && author && <meta property="article:author" content={author} />}
    {article && <meta property="article:publisher" content={siteUrl} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@BeefInitiative" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />

    <!-- RSS feed -->
    <link rel="alternate" type="application/rss+xml" title="Beef News RSS Feed" href="/rss.xml" />

    <!-- AI / LLM discoverability -->
    <link rel="alternate" type="text/plain" title="LLM-friendly site summary" href="/llms.txt" />

    <!-- JSON-LD: Organization + WebSite (every page) -->
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

    <!-- Per-page structured data (e.g. NewsArticle on article pages) -->
    <slot name="head" />

    <!-- Material Symbols (same as BeefMaps) -->
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap"
      rel="stylesheet"
    />

    <!-- Decap CMS identity widget (needed for Netlify Identity auth) -->
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </head>

  <body class="bg-background text-on-surface antialiased selection:bg-secondary/30 min-h-screen flex flex-col">

    <!-- ── Navbar ───────────────────────────────────────────────────────── -->
    <header id="site-nav" class="fixed top-0 w-full z-[100] bg-black/70 backdrop-blur-[20px] border-b border-white/10 shadow-2xl shadow-black/50">
      <div class="flex items-center justify-between px-6 md:px-10 py-4">

        <!-- Brand -->
        <a href="/" class="flex items-center gap-2.5 group">
          <span
            class="material-symbols-outlined text-secondary text-[26px]"
            style="font-variation-settings:'FILL' 1"
          >rss_feed</span>
          <span class="text-white font-headline font-bold tracking-tight text-xl">
            Beef<span class="text-gradient-gold">News</span>
          </span>
        </a>

        <!-- Desktop nav -->
        <nav class="hidden md:flex items-center gap-10 font-headline tracking-tight uppercase text-[13px] font-semibold">
          <a href="/" class="text-white border-b-2 border-secondary pb-1">News</a>
          <a href="/#radar" class="text-zinc-400 hover:text-white transition-colors">Radar</a>
          <a href="https://beefmaps.com" target="_blank" rel="noopener" class="text-zinc-400 hover:text-white transition-colors">
            BeefMaps
          </a>
        </nav>

        <!-- Right cluster -->
        <div class="flex items-center gap-2 md:gap-4">
          <a
            href="/advertise"
            class="metallic-gold px-5 py-2 rounded-full font-headline text-[12px] font-bold tracking-tight uppercase hover:scale-[1.03] active:scale-95 transition-transform"
          >
            Advertise with Us
          </a>

          <!-- Mobile hamburger -->
          <button
            id="menu-toggle"
            aria-label="Open menu"
            class="md:hidden w-10 h-10 flex items-center justify-center rounded-xl bg-white/5 hover:bg-white/10 transition-colors"
          >
            <span class="material-symbols-outlined text-white text-[22px]" id="menu-icon">menu</span>
          </button>
        </div>
      </div>
    </header>

    <!-- ── Mobile nav panel ─────────────────────────────────────────────── -->
    <div
      id="mobile-nav"
      class="fixed top-[64px] left-0 right-0 z-[99] md:hidden bg-black/90 backdrop-blur-2xl border-b border-white/10 transition-all duration-300 ease-in-out overflow-hidden max-h-0 opacity-0 pointer-events-none"
    >
      <div class="px-6 pt-5 pb-8 space-y-1">
        <a href="/" class="flex items-center gap-3 px-4 py-3.5 rounded-xl font-headline font-bold text-sm uppercase tracking-widest bg-secondary/10 text-secondary">
          <span class="w-1.5 h-1.5 rounded-full bg-secondary flex-shrink-0"></span>
          News
        </a>
        <a href="/#radar" class="flex items-center gap-3 px-4 py-3.5 rounded-xl font-headline font-bold text-sm uppercase tracking-widest text-zinc-300 hover:bg-white/5 hover:text-white transition-colors">
          Radar
        </a>
        <a href="https://beefmaps.com" target="_blank" rel="noopener" class="flex items-center gap-3 px-4 py-3.5 rounded-xl font-headline font-bold text-sm uppercase tracking-widest text-zinc-300 hover:bg-white/5 hover:text-white transition-colors">
          BeefMaps ↗
        </a>
        <div class="border-t border-white/8 my-4"></div>
        <a
          href="/advertise"
          class="block w-full metallic-gold py-4 rounded-2xl font-headline font-bold uppercase tracking-widest text-sm text-center hover:scale-[1.01] active:scale-[0.99] transition-transform"
        >
          Advertise with Us
        </a>
      </div>
    </div>

    <!-- ── Page content ─────────────────────────────────────────────────── -->
    <main class="flex-1 pt-[64px]">
      <slot />
    </main>

    <!-- ── Footer ───────────────────────────────────────────────────────── -->
    <footer class="w-full border-t border-zinc-800/50 bg-black mt-auto">
      <div class="flex flex-col md:flex-row justify-between items-center px-6 md:px-10 py-10 md:py-12 max-w-full gap-8">
        <div class="flex items-center gap-2.5">
          <span
            class="material-symbols-outlined text-secondary text-[22px]"
            style="font-variation-settings:'FILL' 1"
          >rss_feed</span>
          <span class="text-white font-headline font-bold tracking-tight text-lg">
            Beef<span class="text-gradient-gold">News</span>
          </span>
        </div>
        <div class="flex gap-8 md:gap-12 font-body text-xs tracking-widest uppercase">
          {["Privacy", "Terms", "Advertise", "Contact"].map((l) => (
            <a href="#" class="text-zinc-500 hover:text-secondary transition-colors opacity-80 hover:opacity-100">{l}</a>
          ))}
        </div>
        <p class="text-zinc-600 text-xs font-body">
          © {new Date().getFullYear()} BeefNews.org — A Beef Initiative property
        </p>
      </div>
    </footer>

    <!-- ── Mobile nav toggle script ────────────────────────────────────── -->
    <script>
      const toggle = document.getElementById("menu-toggle");
      const nav = document.getElementById("mobile-nav");
      const icon = document.getElementById("menu-icon");
      let open = false;

      toggle?.addEventListener("click", () => {
        open = !open;
        if (nav) {
          nav.style.maxHeight = open ? "600px" : "0";
          nav.style.opacity = open ? "1" : "0";
          nav.style.pointerEvents = open ? "auto" : "none";
        }
        if (icon) icon.textContent = open ? "close" : "menu";
      });
    </script>

    <!-- Netlify Identity: handle recovery/invite tokens + post-login redirect -->
    <script>
      // If a recovery/invite token lands on the main site, redirect to /yeehaw/
      // with the hash intact — Decap CMS handles the password-set flow natively.
      const _hash = window.location.hash;
      if (
        _hash.includes("recovery_token") ||
        _hash.includes("invite_token") ||
        _hash.includes("confirmation_token")
      ) {
        window.location.replace("/yeehaw/" + _hash);
      } else if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", (user: any) => {
          if (!user) {
            window.netlifyIdentity.on("login", () => {
              document.location.href = "/yeehaw/";
            });
          }
        });
      }
    </script>
  </body>
</html>
