---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Advertise with BeefNews.org"
  description="Reach engaged ranchers, producers, and beef enthusiasts. Submit an advertising inquiry to partner with BeefNews.org."
>

  <!-- ── Cinematic hero ─────────────────────────────────────────────────── -->
  <section class="relative h-[600px] md:h-[700px] flex items-center justify-center overflow-hidden">
    <!-- Background: atmospheric gradient (swap src for a real ranch photo when available) -->
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-gradient-to-br from-[#1a0f05] via-[#0e0e0e] to-[#1a1208]"></div>
      <!-- Warm gold horizon glow -->
      <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[900px] h-[400px] bg-secondary/5 rounded-full blur-[120px] pointer-events-none"></div>
      <div class="absolute top-1/3 left-1/3 w-[600px] h-[300px] bg-secondary/3 rounded-full blur-[160px] pointer-events-none"></div>
      <!-- Fade to page bg at bottom so form overlaps smoothly -->
      <div class="absolute inset-x-0 bottom-0 h-48 bg-gradient-to-t from-background to-transparent"></div>
    </div>

    <div class="relative z-10 text-center px-6 max-w-4xl">
      <h1 class="font-headline text-5xl md:text-7xl font-bold tracking-tighter text-white mb-6">
        Advertise with <span class="text-gradient-gold">BeefNews.org</span>
      </h1>
      <p class="text-lg md:text-xl text-zinc-400 max-w-2xl mx-auto leading-relaxed">
        Reach engaged ranchers, producers, and beef enthusiasts who value transparency
        and direct-from-ranch connections.
      </p>
    </div>
  </section>

  <!-- ── Form (overlaps hero) ───────────────────────────────────────────── -->
  <section class="max-w-4xl mx-auto px-6 -mt-28 pb-32 relative z-20">

    <form
      name="advertise"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      action="/advertise/success"
      class="space-y-10"
    >
      <!-- Honeypot -->
      <input type="hidden" name="form-name" value="advertise" />
      <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>

      <!-- ── 1. Contact Information ───────────────────────────────────── -->
      <div class="glass-panel p-8 md:p-12 rounded-xl shadow-2xl">
        <div class="flex items-center gap-4 mb-8">
          <span class="material-symbols-outlined text-secondary text-[32px]">contact_mail</span>
          <h2 class="font-headline text-2xl font-bold tracking-tight uppercase text-white">
            Contact Information
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-2">
            <label class="block text-sm font-label font-medium uppercase tracking-widest text-zinc-500">
              Full Name <span class="text-secondary">*</span>
            </label>
            <input
              type="text"
              name="full-name"
              required
              placeholder="Jane Rancher"
              class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-lg px-4 py-3 text-sm font-body text-on-surface placeholder:text-zinc-700 focus:outline-none focus:ring-2 focus:ring-secondary/40 transition-all"
            />
          </div>

          <div class="space-y-2">
            <label class="block text-sm font-label font-medium uppercase tracking-widest text-zinc-500">
              Email <span class="text-secondary">*</span>
            </label>
            <input
              type="email"
              name="email"
              required
              placeholder="jane@yourranch.com"
              class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-lg px-4 py-3 text-sm font-body text-on-surface placeholder:text-zinc-700 focus:outline-none focus:ring-2 focus:ring-secondary/40 transition-all"
            />
          </div>

          <div class="space-y-2">
            <label class="block text-sm font-label font-medium uppercase tracking-widest text-zinc-500">
              Phone <span class="text-zinc-700 normal-case tracking-normal font-normal text-xs">(optional)</span>
            </label>
            <input
              type="tel"
              name="phone"
              placeholder="+1 (555) 000-0000"
              class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-lg px-4 py-3 text-sm font-body text-on-surface placeholder:text-zinc-700 focus:outline-none focus:ring-2 focus:ring-secondary/40 transition-all"
            />
          </div>

          <div class="space-y-2">
            <label class="block text-sm font-label font-medium uppercase tracking-widest text-zinc-500">
              Company Name <span class="text-secondary">*</span>
            </label>
            <input
              type="text"
              name="company"
              required
              placeholder="Lone Star Beef Co."
              class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-lg px-4 py-3 text-sm font-body text-on-surface placeholder:text-zinc-700 focus:outline-none focus:ring-2 focus:ring-secondary/40 transition-all"
            />
          </div>
        </div>
      </div>

      <!-- ── 2. Business Details ──────────────────────────────────────── -->
      <div class="glass-panel p-8 md:p-12 rounded-xl shadow-2xl">
        <div class="flex items-center gap-4 mb-8">
          <span class="material-symbols-outlined text-secondary text-[32px]">corporate_fare</span>
          <h2 class="font-headline text-2xl font-bold tracking-tight uppercase text-white">
            Business Details
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-2">
            <label class="block text-sm font-label font-medium uppercase tracking-widest text-zinc-500">
              Business Type <span class="text-secondary">*</span>
            </label>
            <div class="relative">
              <select
                name="business-type"
                required
                class="w-full appearance-none bg-surface-container-lowest border border-outline-variant/20 rounded-lg px-4 py-3 text-sm font-body text-on-surface focus:outline-none focus:ring-2 focus:ring-secondary/40 transition-all pr-10"
              >
                <option value="" disabled selected>Select your business type…</option>
                <option>Ranch / Cattle Producer (direct sales)</option>
                <option>Beef Processor / Butcher / Brand</option>
                <option>Feed / Supplement / Equipment Supplier</option>
                <option>Event Organizer (sale, conference, festival)</option>
                <option>Agribusiness / Service Provider</option>
                <option>Nonprofit / Advocacy Group</option>
                <option>Other (please specify)</option>
              </select>
              <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-zinc-500 text-[20px] pointer-events-none">expand_more</span>
            </div>
          </div>

          <div class="space-y-2">
            <label class="block text-sm font-label font-medium uppercase tracking-widest text-zinc-500">
              Website URL <span class="text-zinc-700 normal-case tracking-normal font-normal text-xs">(optional)</span>
            </label>
            <input
              type="url"
              name="website"
              placeholder="https://yourranch.com"
              class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-lg px-4 py-3 text-sm font-body text-on-surface placeholder:text-zinc-700 focus:outline-none focus:ring-2 focus:ring-secondary/40 transition-all"
            />
          </div>
        </div>
      </div>

      <!-- ── 3. Advertising Interest ─────────────────────────────────── -->
      <div class="glass-panel p-8 md:p-12 rounded-xl shadow-2xl">
        <div class="flex items-center gap-4 mb-8">
          <span class="material-symbols-outlined text-secondary text-[32px]">campaign</span>
          <h2 class="font-headline text-2xl font-bold tracking-tight uppercase text-white">
            Advertising Interest
          </h2>
        </div>

        <div class="space-y-8">
          <!-- Ad type checkboxes -->
          <div class="space-y-4">
            <label class="block text-sm font-label font-medium uppercase tracking-widest text-zinc-500">
              Ad Type (Select all that apply) <span class="text-secondary">*</span>
            </label>
            <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
              {[
                "Sponsored Article",
                "Banner / Display",
                "Newsletter Feature",
                "Rancher Sponsorship",
                "Event Promotion",
                "Custom Package",
                "Other",
              ].map((opt) => (
                <label class="flex items-center gap-3 cursor-pointer group">
                  <input
                    type="checkbox"
                    name="ad-type"
                    value={opt}
                    class="rounded border-outline-variant bg-surface-container-lowest accent-secondary"
                  />
                  <span class="text-sm font-body text-on-surface group-hover:text-secondary transition-colors">{opt}</span>
                </label>
              ))}
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label class="block text-sm font-label font-medium uppercase tracking-widest text-zinc-500">
                Duration
              </label>
              <div class="relative">
                <select
                  name="duration"
                  class="w-full appearance-none bg-surface-container-lowest border border-outline-variant/20 rounded-lg px-4 py-3 text-sm font-body text-on-surface focus:outline-none focus:ring-2 focus:ring-secondary/40 transition-all pr-10"
                >
                  <option value="" disabled selected>Select duration…</option>
                  <option>One-time / Single post</option>
                  <option>1 month</option>
                  <option>3 months</option>
                  <option>6 months</option>
                  <option>Ongoing / Annual</option>
                  <option>Not sure yet</option>
                </select>
                <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-zinc-500 text-[20px] pointer-events-none">expand_more</span>
              </div>
            </div>

            <div class="space-y-2">
              <label class="block text-sm font-label font-medium uppercase tracking-widest text-zinc-500">
                Budget Range
              </label>
              <div class="relative">
                <select
                  name="budget"
                  class="w-full appearance-none bg-surface-container-lowest border border-outline-variant/20 rounded-lg px-4 py-3 text-sm font-body text-on-surface focus:outline-none focus:ring-2 focus:ring-secondary/40 transition-all pr-10"
                >
                  <option value="" disabled selected>Select budget range…</option>
                  <option>Under $500</option>
                  <option>$500 – $1,500</option>
                  <option>$1,500 – $5,000</option>
                  <option>$5,000 – $10,000</option>
                  <option>Over $10,000</option>
                  <option>Flexible / Not sure</option>
                </select>
                <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-zinc-500 text-[20px] pointer-events-none">expand_more</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ── 4. Goals & Targeting ────────────────────────────────────── -->
      <div class="glass-panel p-8 md:p-12 rounded-xl shadow-2xl">
        <div class="flex items-center gap-4 mb-8">
          <span class="material-symbols-outlined text-secondary text-[32px]">target</span>
          <h2 class="font-headline text-2xl font-bold tracking-tight uppercase text-white">
            Goals &amp; Targeting
          </h2>
        </div>

        <div class="space-y-6">
          <!-- Goal checkboxes -->
          <div class="space-y-4">
            <label class="block text-sm font-label font-medium uppercase tracking-widest text-zinc-500">
              Primary Goals
            </label>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {[
                "Brand Awareness",
                "Direct Sales / Leads",
                "Event Promotion",
                "Educational / Policy Reach",
                "Drive Website Traffic",
                "Other (please describe)",
              ].map((opt) => (
                <label class="flex items-center gap-3 cursor-pointer group">
                  <input
                    type="checkbox"
                    name="goal"
                    value={opt}
                    class="rounded border-outline-variant bg-surface-container-lowest accent-secondary"
                  />
                  <span class="text-sm font-body text-on-surface group-hover:text-secondary transition-colors">{opt}</span>
                </label>
              ))}
            </div>
          </div>

          <div class="space-y-2">
            <label class="block text-sm font-label font-medium uppercase tracking-widest text-zinc-500">
              Target Audience Details
            </label>
            <textarea
              name="target-audience"
              rows="3"
              placeholder="Describe your ideal demographic — e.g., independent ranchers, regenerative producers, direct beef buyers…"
              class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-lg px-4 py-3 text-sm font-body text-on-surface placeholder:text-zinc-700 focus:outline-none focus:ring-2 focus:ring-secondary/40 transition-all resize-none"
            ></textarea>
          </div>
        </div>
      </div>

      <!-- ── 5. Creative & Message ───────────────────────────────────── -->
      <div class="glass-panel p-8 md:p-12 rounded-xl shadow-2xl">
        <div class="flex items-center gap-4 mb-8">
          <span class="material-symbols-outlined text-secondary text-[32px]">brush</span>
          <h2 class="font-headline text-2xl font-bold tracking-tight uppercase text-white">
            Creative &amp; Message
          </h2>
        </div>

        <div class="space-y-6">
          <div class="space-y-2">
            <label class="block text-sm font-label font-medium uppercase tracking-widest text-zinc-500">
              Promo Description <span class="text-secondary">*</span>
            </label>
            <textarea
              name="promotion-description"
              required
              rows="4"
              placeholder="Briefly describe the product or service you wish to promote…"
              class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-lg px-4 py-3 text-sm font-body text-on-surface placeholder:text-zinc-700 focus:outline-none focus:ring-2 focus:ring-secondary/40 transition-all resize-none"
            ></textarea>
          </div>

          <div class="space-y-4">
            <label class="block text-sm font-label font-medium uppercase tracking-widest text-zinc-500">
              Asset Readiness
            </label>
            <div class="flex flex-wrap gap-8">
              {[
                ["yes", "Assets Ready"],
                ["no",  "Need Design Support"],
                ["unsure", "Concept Phase"],
              ].map(([val, label]) => (
                <label class="flex items-center gap-3 cursor-pointer group">
                  <input
                    type="radio"
                    name="assets-ready"
                    value={val}
                    class="border-outline-variant bg-surface-container-lowest accent-secondary"
                  />
                  <span class="text-sm font-body text-on-surface group-hover:text-secondary transition-colors">{label}</span>
                </label>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- ── 6. Additional Info ──────────────────────────────────────── -->
      <div class="glass-panel p-8 md:p-12 rounded-xl shadow-2xl">
        <div class="flex items-center gap-4 mb-8">
          <span class="material-symbols-outlined text-secondary text-[32px]">info</span>
          <h2 class="font-headline text-2xl font-bold tracking-tight uppercase text-white">
            Additional Info
          </h2>
        </div>

        <div class="space-y-6">
          <div class="space-y-2">
            <label class="block text-sm font-label font-medium uppercase tracking-widest text-zinc-500">
              How did you hear about us?
            </label>
            <div class="relative">
              <select
                name="referral-source"
                class="w-full appearance-none bg-surface-container-lowest border border-outline-variant/20 rounded-lg px-4 py-3 text-sm font-body text-on-surface focus:outline-none focus:ring-2 focus:ring-secondary/40 transition-all pr-10"
              >
                <option value="" selected>Prefer not to say</option>
                <option>Social Media</option>
                <option>Industry Referral</option>
                <option>Search Engine</option>
                <option>Email Newsletter</option>
                <option>Other</option>
              </select>
              <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-zinc-500 text-[20px] pointer-events-none">expand_more</span>
            </div>
          </div>

          <div class="space-y-2">
            <label class="block text-sm font-label font-medium uppercase tracking-widest text-zinc-500">
              Notes or Special Requests
            </label>
            <textarea
              name="notes"
              rows="4"
              placeholder="Any specific details we should know…"
              class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-lg px-4 py-3 text-sm font-body text-on-surface placeholder:text-zinc-700 focus:outline-none focus:ring-2 focus:ring-secondary/40 transition-all resize-none"
            ></textarea>
          </div>
        </div>
      </div>

      <!-- ── Submit ─────────────────────────────────────────────────── -->
      <div class="flex justify-center pt-4">
        <button
          type="submit"
          class="metallic-gold text-[#2a1700] font-headline font-black text-xl uppercase tracking-tighter px-12 py-5 rounded-lg shadow-[0_20px_50px_rgba(238,152,0,0.3)] hover:scale-105 active:scale-95 transition-all duration-300 flex items-center gap-3 group"
        >
          Submit Advertising Inquiry
          <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
        </button>
      </div>

    </form>
  </section>

</BaseLayout>
