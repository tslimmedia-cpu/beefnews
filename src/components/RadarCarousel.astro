---
interface RadarItem {
  title: string;
  excerpt: string;
  image?: string;
  category: string;
  pubDate: Date;
  slug: string;
  externalUrl?: string;
}

interface Props {
  items: RadarItem[];
}

const { items } = Astro.props;

const loop = [...items, ...items]; // double for seamless CSS marquee

function relDate(d: Date): string {
  const diff = Date.now() - d.getTime();
  const days = Math.floor(diff / 86_400_000);
  if (days === 0) return "Today";
  if (days === 1) return "Yesterday";
  if (days < 7) return `${days}d ago`;
  return d.toLocaleDateString("en-US", { month: "short", day: "numeric" });
}

const FALLBACK = "https://images.unsplash.com/photo-1558642084-fd07fae5282e?w=400&q=75";
---

<section id="radar" class="bg-surface-container-low py-20 md:py-24 overflow-hidden">
  <!-- Section header -->
  <div class="max-w-7xl mx-auto px-6 md:px-10 mb-10 md:mb-12">
    <div class="flex items-center gap-4">
      <span class="w-12 h-[1px] bg-secondary"></span>
      <h2 class="text-xl md:text-2xl font-headline font-bold tracking-tighter uppercase text-gradient-gold">
        Beef News Radar
      </h2>
      <span class="w-2 h-2 rounded-full bg-secondary animate-pin-pulse"></span>
    </div>
    <p class="mt-2 ml-16 text-xs font-label text-zinc-500 uppercase tracking-widest">
      Breaking signals from the industry
    </p>
  </div>

  <!-- Marquee strip -->
  <div class="group relative overflow-hidden">
    <div class="flex gap-6 px-6 md:px-10 animate-marquee group-hover:[animation-play-state:paused] w-max">
      {loop.map((item, i) => (
        <a
          href={item.externalUrl ?? `/${item.slug}`}
          target={item.externalUrl ? "_blank" : "_self"}
          rel={item.externalUrl ? "noopener noreferrer" : undefined}
          class="w-[360px] md:w-[400px] glass-panel p-5 md:p-6 rounded-2xl flex gap-5 items-center hover:bg-surface-variant/30 transition-all cursor-pointer shrink-0 no-underline"
        >
          <!-- Thumbnail -->
          <div class="w-20 h-20 md:w-24 md:h-24 rounded-xl overflow-hidden shrink-0 bg-surface-container-highest">
            <img
              src={item.image ?? FALLBACK}
              alt=""
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>

          <!-- Text -->
          <div class="min-w-0">
            <div class="flex items-center gap-2 mb-2">
              <span class="text-[10px] font-headline font-bold text-secondary uppercase tracking-[0.2em] truncate">
                {item.category}
              </span>
              <span class="text-[10px] text-zinc-600 shrink-0">
                · {relDate(item.pubDate)}
              </span>
            </div>
            <h4 class="font-headline font-bold text-base md:text-lg text-white leading-tight line-clamp-3">
              {item.title}
            </h4>
          </div>
        </a>
      ))}
    </div>

    <!-- Edge fade masks -->
    <div class="absolute inset-y-0 left-0 w-16 bg-gradient-to-r from-surface-container-low to-transparent pointer-events-none z-10"></div>
    <div class="absolute inset-y-0 right-0 w-16 bg-gradient-to-l from-surface-container-low to-transparent pointer-events-none z-10"></div>
  </div>
</section>
